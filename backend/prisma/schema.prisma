generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  community_admin
  reception
  resident
}

enum TenantStatus {
  active
  suspended
  cancelled
}

enum PlanType {
  basic
  standard
  premium
}

// ─── TENANT & SUBSCRIPTION ──────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  subscription Subscription?
  users        User[]
  communities  Community[]
  auditLogs    AuditLog[]

  @@map("tenants")
}

model Subscription {
  id                 String   @id @default(uuid())
  tenantId           String   @unique @map("tenant_id")
  plan               PlanType @default(basic)
  maxCommunities     Int      @default(1) @map("max_communities")
  maxUnitsPerCommunity Int    @default(50) @map("max_units_per_community")
  startsAt           DateTime @default(now()) @map("starts_at")
  expiresAt          DateTime? @map("expires_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

// ─── USER & AUTH ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String?   @map("tenant_id")
  communityId  String?   @map("community_id")
  email        String    @unique
  password     String
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  role         UserRole  @default(resident)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  community    Community? @relation(fields: [communityId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model Community {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  address   String?
  city      String?
  state     String?
  country   String    @default("CO")
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  users         User[]
  units         Unit[]
  employees     Employee[]
  visitors      Visitor[]
  accessLogs    AccessLog[]
  packages      Package[]
  documents     Document[]
  announcements Announcement[]
  pqrsRequests  PQRS[]

  @@map("communities")
}

// ─── UNIT ────────────────────────────────────────────────────────────────────

model Unit {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  identifier  String                          // e.g. "Apt 301", "House 12"
  block       String?                         // tower/block/section
  floor       String?
  type        String?                         // apartment, house, duplex
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  community Community  @relation(fields: [communityId], references: [id])
  residents Resident[]
  visitors  Visitor[]
  packages  Package[]
  pqrsRequests PQRS[]

  @@unique([communityId, identifier])
  @@map("units")
}

// ─── RESIDENT ────────────────────────────────────────────────────────────────

model Resident {
  id          String    @id @default(uuid())
  unitId      String    @map("unit_id")
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  email       String?
  phone       String?
  isOwner     Boolean   @default(false) @map("is_owner")
  moveInDate  DateTime? @map("move_in_date")
  moveOutDate DateTime? @map("move_out_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  unit     Unit      @relation(fields: [unitId], references: [id])
  visitors Visitor[]

  @@map("residents")
}

// ─── EMPLOYEE ────────────────────────────────────────────────────────────────

model Employee {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  email       String?
  phone       String?
  position    String                          // security, maintenance, admin, etc.
  isActive    Boolean   @default(true) @map("is_active")
  hireDate    DateTime? @map("hire_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  community Community @relation(fields: [communityId], references: [id])

  @@map("employees")
}

// ─── VISITOR & ACCESS ────────────────────────────────────────────────────────

model Visitor {
  id             String    @id @default(uuid())
  communityId    String    @map("community_id")
  unitId         String    @map("unit_id")
  residentId     String?   @map("resident_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  documentType   String?   @map("document_type")    // CC, passport, etc.
  documentNumber String?   @map("document_number")
  phone          String?
  vehiclePlate   String?   @map("vehicle_plate")
  reason         String?
  isPreAuthorized Boolean  @default(false) @map("is_pre_authorized")
  authorizedFrom DateTime? @map("authorized_from")
  authorizedUntil DateTime? @map("authorized_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  community  Community   @relation(fields: [communityId], references: [id])
  unit       Unit        @relation(fields: [unitId], references: [id])
  resident   Resident?   @relation(fields: [residentId], references: [id])
  accessLogs AccessLog[]

  @@map("visitors")
}

model AccessLog {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  visitorId   String    @map("visitor_id")
  checkInAt   DateTime  @default(now()) @map("check_in_at")
  checkOutAt  DateTime? @map("check_out_at")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id])
  visitor   Visitor   @relation(fields: [visitorId], references: [id])

  @@map("access_logs")
}

// ─── PACKAGES ────────────────────────────────────────────────────────────────

model Package {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  unitId      String    @map("unit_id")
  carrier     String?                        // FedEx, Rappi, etc.
  description String?
  receivedAt  DateTime  @default(now()) @map("received_at")
  deliveredAt DateTime? @map("delivered_at")
  receivedBy  String?   @map("received_by")  // employee name
  deliveredTo String?   @map("delivered_to") // resident name
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  unit      Unit      @relation(fields: [unitId], references: [id])

  @@map("packages")
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model Document {
  id          String   @id @default(uuid())
  communityId String   @map("community_id")
  title       String
  description String?
  fileUrl     String   @map("file_url")
  category    String?                       // rules, minutes, forms, etc.
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  community Community @relation(fields: [communityId], references: [id])

  @@map("documents")
}

// ─── ANNOUNCEMENTS ───────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  title       String
  content     String
  priority    String    @default("normal")   // low, normal, high, urgent
  publishedAt DateTime  @default(now()) @map("published_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  community Community @relation(fields: [communityId], references: [id])

  @@map("announcements")
}

// ─── PQRS ────────────────────────────────────────────────────────────────────

model PQRS {
  id          String   @id @default(uuid())
  communityId String   @map("community_id")
  unitId      String   @map("unit_id")
  type        String                         // petition, question, complaint, suggestion
  subject     String
  description String
  status      String   @default("open")      // open, in_progress, resolved, closed
  response    String?
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  unit      Unit      @relation(fields: [unitId], references: [id])

  @@map("pqrs")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  userId    String?  @map("user_id")
  action    String                           // create, update, delete, login, etc.
  entity    String                           // table/model name
  entityId  String?  @map("entity_id")
  changes   Json?                            // { before, after }
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
